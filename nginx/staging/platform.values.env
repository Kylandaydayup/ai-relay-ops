## Required staging host and port configuration.
## Change these when moving the whole stack to another machine or NodePort layout.
HTTP_LISTEN_PORT=80
HTTPS_LISTEN_PORT=443
PUBLIC_IP=139.196.254.8
HOST_UPSTREAM_IP=127.0.0.1
NEWAPI_NODE_PORT=30081
BROKER_NODE_PORT=30080
CASDOOR_NODE_PORT=30082
EDREAMCROWD_BACKEND_NODE_PORT=30083
EDREAMCROWD_FRONTEND_NODE_PORT=30084
COMPAT_LISTEN_PORT=3000

## Optional domain routing.
## Leave a value empty to skip that domain-specific nginx server block.
HTTP_SERVER_NAMES="_ 139.196.254.8 nexushome.top www.nexushome.top"
HTTPS_SERVER_NAME=www.nexushome.top
API_SERVER_NAME=api.nexushome.top
AUTH_SERVER_NAME=auth.nexushome.top
ZHONGCHOU_SERVER_NAME=zhongchou.nexushome.top
ARCREEL_SERVER_NAME=arcreel.nexushome.top
HTTPS_CERTIFICATE=/etc/letsencrypt/live/www.nexushome.top/fullchain.pem
HTTPS_CERTIFICATE_KEY=/etc/letsencrypt/live/www.nexushome.top/privkey.pem
HTTPS_OPTIONS=/etc/letsencrypt/options-ssl-nginx.conf
HTTPS_DH_PARAM=/etc/letsencrypt/ssl-dhparams.pem

CLIENT_MAX_BODY_SIZE=500m
HTTPS_CLIENT_MAX_BODY_SIZE=128m

ROOT_NEWAPI_UPSTREAM=http://${HOST_UPSTREAM_IP}:${NEWAPI_NODE_PORT}
RELAY_NEWAPI_UPSTREAM=http://${HOST_UPSTREAM_IP}:${NEWAPI_NODE_PORT}
RELAY_BROKER_UPSTREAM=http://${HOST_UPSTREAM_IP}:${BROKER_NODE_PORT}
CASDOOR_UPSTREAM=http://${HOST_UPSTREAM_IP}:${CASDOOR_NODE_PORT}
EDREAMCROWD_BACKEND_UPSTREAM=http://${HOST_UPSTREAM_IP}:${EDREAMCROWD_BACKEND_NODE_PORT}
EDREAMCROWD_FRONTEND_UPSTREAM=http://${HOST_UPSTREAM_IP}:${EDREAMCROWD_FRONTEND_NODE_PORT}

DOWNLOAD_PATH=/downloads/edream/latest
DOWNLOAD_REDIRECT_URL=https://download.arc-reel.com/edream/latest
CASDOOR_BASE_PATH=/casdoor
CASDOOR_BASE_PATH_SLASH=/casdoor/
CASDOOR_DEFAULT_LOGIN_PATH=/casdoor/login/edream
CASDOOR_DEFAULT_AFTER_LOGIN_URL=http://${PUBLIC_IP}/zhongchou/
NEWAPI_BASE_PATH=/new-api
NEWAPI_BASE_PATH_SLASH=/new-api/
NEWAPI_OLD_BASE_PATH=/new-api-k8s/
BROKER_BASE_PATH=/broker/
BROKER_INTERNAL_PATH=/broker/internal/
ZHONGCHOU_BASE_PATH=/zhongchou
ZHONGCHOU_BASE_PATH_SLASH=/zhongchou/
ZHONGCHOU_API_PATH=/zhongchou_api/
OAUTH_PATH=/oauth2/
LOGIN_OAUTH_PATH=/login/oauth2/

# Copy to build/platform-images.harbor.env and edit source paths/refs.

HARBOR_ENV_FILE=build/harbor.env
BUILD_WORKDIR=.build/harbor-platform-images

# One timestamp is shared by all images in a build run.
IMAGE_TAG_TIMESTAMP=
IMAGE_BRANCH=

BUILD_BROKER=true
BROKER_REPO_URL=
BROKER_REPO_REF=main
BROKER_LOCAL_DIR=../ai-relay-broker
BROKER_CONTEXT=.
BROKER_DOCKERFILE=Dockerfile
BROKER_IMAGE_NAME=broker
BROKER_BUILD_ARGS=PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

BUILD_AI_PROVIDER_ADAPTER=true
AI_PROVIDER_ADAPTER_REPO_URL=
AI_PROVIDER_ADAPTER_REPO_REF=main
AI_PROVIDER_ADAPTER_LOCAL_DIR=../ai-relay-broker
AI_PROVIDER_ADAPTER_CONTEXT=.
AI_PROVIDER_ADAPTER_DOCKERFILE=Dockerfile.ai-provider-adapter
AI_PROVIDER_ADAPTER_IMAGE_NAME=ai-provider-adapter
AI_PROVIDER_ADAPTER_BUILD_ARGS=PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

BUILD_NEWAPI_COMPAT_GATEWAY=true
NEWAPI_COMPAT_GATEWAY_REPO_URL=
NEWAPI_COMPAT_GATEWAY_REPO_REF=main
NEWAPI_COMPAT_GATEWAY_LOCAL_DIR=../ai-relay-broker
NEWAPI_COMPAT_GATEWAY_CONTEXT=.
NEWAPI_COMPAT_GATEWAY_DOCKERFILE=Dockerfile.newapi-compat-gateway
NEWAPI_COMPAT_GATEWAY_IMAGE_NAME=newapi-compat-gateway
NEWAPI_COMPAT_GATEWAY_BUILD_ARGS=PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

BUILD_EDREAMCROWD_BACKEND=false
EDREAMCROWD_REPO_URL=
EDREAMCROWD_REPO_REF=main
EDREAMCROWD_LOCAL_DIR=../EDreamCrowd
EDREAMCROWD_BACKEND_CONTEXT=.
EDREAMCROWD_BACKEND_DOCKERFILE=Dockerfile
EDREAMCROWD_BACKEND_IMAGE_NAME=backend
EDREAMCROWD_BACKEND_BUILD_ARGS=

BUILD_EDREAMCROWD_FRONTEND=false
EDREAMCROWD_FRONTEND_CONTEXT=frontend
EDREAMCROWD_FRONTEND_DOCKERFILE=Dockerfile
EDREAMCROWD_FRONTEND_IMAGE_NAME=frontend
EDREAMCROWD_FRONTEND_BUILD_ARGS=VITE_PUBLIC_BASE=/

BUILD_NEW_API=false
NEW_API_REPO_URL=
NEW_API_REPO_REF=main
NEW_API_LOCAL_DIR=../new-api
NEW_API_CONTEXT=.
NEW_API_DOCKERFILE=Dockerfile
NEW_API_IMAGE_NAME=new-api
NEW_API_BUILD_ARGS=

BUILD_CASDOOR=false
CASDOOR_REPO_URL=
CASDOOR_REPO_REF=main
CASDOOR_LOCAL_DIR=../casdoor
CASDOOR_CONTEXT=.
CASDOOR_DOCKERFILE=Dockerfile
CASDOOR_IMAGE_NAME=casdoor
CASDOOR_BUILD_ARGS=

# Space-separated upstream/base images to mirror into Harbor base-images.
BASE_IMAGES="postgres:16-alpine nginx:alpine node:20-alpine node:22-slim python:3.12-slim debian:bookworm-slim alpine:latest"

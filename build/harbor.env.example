# Copy to build/harbor.env and fill secrets locally. Do not commit real secrets.

HARBOR_SCHEME=http
HARBOR_HOST=81.71.122.120
HARBOR_PORT=80

HARBOR_ADMIN_USER=admin
HARBOR_ADMIN_PASSWORD=

HARBOR_BASE_PROJECT=base-images
HARBOR_CACHE_PROJECT=build-cache
HARBOR_RUNTIME_PROJECT=platform

# Space-separated upstream/base images to mirror into Harbor base-images.
BASE_IMAGES="postgres:16-alpine nginx:alpine node:20-alpine node:22-slim python:3.12-slim debian:bookworm-slim alpine:latest maven:3.9.9-eclipse-temurin-21 eclipse-temurin:21-jre"

# Optional robot account for build/push after Harbor is initialized.
HARBOR_USERNAME=
HARBOR_PASSWORD=

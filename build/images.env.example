# Copy to build/images.env and edit for the source repositories and image tags
# you want to package. Values in this file do not affect a running cluster until
# the generated image names are also written into environments/<env>/values.yaml.

IMAGE_REGISTRY=
IMAGE_OUTPUT_DIR=dist/platform-bundle/images
BUILD_WORKDIR=.build/platform-images
PUSH_IMAGES=false
SAVE_IMAGES=true

BROKER_REPO_URL=https://github.com/example/ai-relay-broker.git
BROKER_REPO_REF=main
BROKER_LOCAL_DIR=
BROKER_IMAGE_REPOSITORY=ai-relay-broker
BROKER_IMAGE_TAG=demo
BROKER_DOCKERFILE=Dockerfile
BROKER_CONTEXT=.
BUILD_BROKER=true
BROKER_BUILD_ARGS=PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

AI_PROVIDER_ADAPTER_REPO_URL=https://github.com/example/ai-relay-broker.git
AI_PROVIDER_ADAPTER_REPO_REF=main
AI_PROVIDER_ADAPTER_LOCAL_DIR=
AI_PROVIDER_ADAPTER_IMAGE_REPOSITORY=ai-provider-adapter
AI_PROVIDER_ADAPTER_IMAGE_TAG=demo
AI_PROVIDER_ADAPTER_DOCKERFILE=Dockerfile.ai-provider-adapter
AI_PROVIDER_ADAPTER_CONTEXT=.
BUILD_AI_PROVIDER_ADAPTER=true
AI_PROVIDER_ADAPTER_BUILD_ARGS=PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

EDREAMCROWD_REPO_URL=https://github.com/example/EDreamCrowd.git
EDREAMCROWD_REPO_REF=main
EDREAMCROWD_LOCAL_DIR=
EDREAMCROWD_FRONTEND_IMAGE_REPOSITORY=edreamcrowd-frontend
EDREAMCROWD_FRONTEND_IMAGE_TAG=demo
EDREAMCROWD_BACKEND_IMAGE_REPOSITORY=edreamcrowd-backend
EDREAMCROWD_BACKEND_IMAGE_TAG=demo
BUILD_EDREAMCROWD_FRONTEND=true
BUILD_EDREAMCROWD_BACKEND=true
EDREAMCROWD_FRONTEND_PUBLIC_BASE=/
EDREAMCROWD_FRONTEND_BUILD_ARGS="NODE_BASE_IMAGE=node:20-alpine NGINX_BASE_IMAGE=nginx:alpine"
EDREAMCROWD_BACKEND_BUILD_ARGS="MAVEN_BASE_IMAGE=maven:3.9.9-eclipse-temurin-21 RUNTIME_BASE_IMAGE=eclipse-temurin:21-jre"

# Space-separated upstream images to pull and save into the bundle.
UPSTREAM_IMAGES=postgres:16-alpine calciumion/new-api:latest casbin/casdoor:latest nginx:alpine

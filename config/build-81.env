# Standard build configuration for the 81.71.122.120 build host.
# This file is safe to commit because passwords and tokens are intentionally empty.
# Runtime deployment differences are not configured here; use environments/<env>/edream-deployment.yaml.

HARBOR_REGISTRY=81.71.122.120
HARBOR_BUILD_REGISTRY=127.0.0.1:8088
HARBOR_SCHEME=http
HARBOR_PORT=80
HARBOR_USERNAME=
HARBOR_PASSWORD=
HARBOR_ADMIN_USER=admin
HARBOR_ADMIN_PASSWORD=

HARBOR_BASE_PROJECT=base-images
HARBOR_RUNTIME_PROJECT=platform

IMAGE_PLATFORM=linux/amd64
IMAGE_REF_LABEL=main
DOCKER_BUILDKIT=1
USE_BUILDX=1
USE_BUILDX_LOCAL_CACHE=0

BUILD_ROOT=/data/edream-build
BUILD_CACHE_ROOT=/data/edream-build/cache
BUILD_PACKAGE_DIR=/data/edream-build/packages

REMOTE_BUILD_HOST=81.71.122.120
REMOTE_BUILD_USER=ubuntu
REMOTE_BUILD_TARGET=
REMOTE_OPS_DIR=/data/edream-build/sources/ai-relay-ops
REMOTE_SSH_OPTS=-o StrictHostKeyChecking=accept-new

GO_CACHE_DIR=/data/edream-build/cache/go
MAVEN_CACHE_DIR=/data/edream-build/cache/maven
NODE_CACHE_DIR=/data/edream-build/cache/node
BUN_CACHE_DIR=/data/edream-build/cache/bun
PIP_CACHE_DIR=/data/edream-build/cache/pip

PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
GO_PROXY=https://goproxy.cn,direct
MAVEN_MIRROR_URL=https://maven.aliyun.com/repository/public

BROKER_LOCAL_DIR=/data/edream-build/sources/ai-relay-broker
BROKER_UPLOAD_DIR=../ai-relay-broker
BROKER_GIT_URL=
BROKER_GIT_REF=main

NEW_API_LOCAL_DIR=/data/edream-build/sources/new-api
NEW_API_UPLOAD_DIR=../new-api
NEW_API_GIT_URL=
NEW_API_GIT_REF=main

CASDOOR_LOCAL_DIR=/data/edream-build/sources/casdoor
CASDOOR_UPLOAD_DIR=../casdoor
CASDOOR_GIT_URL=
CASDOOR_GIT_REF=main

EDREAMCROWD_LOCAL_DIR=/data/edream-build/sources/EDreamCrowd
EDREAMCROWD_UPLOAD_DIR=../EDreamCrowd
EDREAMCROWD_GIT_URL=
EDREAMCROWD_GIT_REF=main

UPLOAD_TARGETS=ops broker new-api edreamcrowd
ALLOW_DIRTY_UPLOAD=0
SOURCE_ALLOW_DIRTY=0
SOURCE_GIT_DEPTH=1

CASDOOR_IMAGE=
BUILD_CASDOOR=0
SYNC_CASDOOR=0

MIN_BUILD_FREE_GB=10
MIN_CASDOOR_BUILD_FREE_GB=15
MIN_BUILD_AVAILABLE_MEM_MB=2048
MIN_CASDOOR_BUILD_AVAILABLE_MEM_MB=4096
PACKAGE_KEEP_COUNT=5
DOCKER_CACHE_KEEP=24h
ROLLOUT_TIMEOUT=600s

# Set this on the build host when a build should update image tags in one values file.
# Example: DEPLOYMENT_VALUES_FILE=/data/edream-build/sources/ai-relay-ops/environments/139/edream-deployment.yaml
DEPLOYMENT_VALUES_FILE=
